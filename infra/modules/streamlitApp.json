{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "2901021938555952045"
    }
  },
  "parameters": {
    "enabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Whether to create the Streamlit Container App resources."
      }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "rxo-streamlit",
      "metadata": {
        "description": "Name prefix for the Container App resources."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the Container App resources."
      }
    },
    "acrLoginServer": {
      "type": "string",
      "metadata": {
        "description": "ACR login server (e.g. myacr.azurecr.io)."
      }
    },
    "acrUsername": {
      "type": "securestring",
      "metadata": {
        "description": "ACR admin username."
      }
    },
    "acrPassword": {
      "type": "securestring",
      "metadata": {
        "description": "ACR admin password."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "streamlit-ui:v1",
      "metadata": {
        "description": "Container image including tag (e.g. streamlit-ui:v1)."
      }
    },
    "storageAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Storage account name for blob access from the Streamlit UI."
      }
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Foundry project endpoint for agents page status display."
      }
    },
    "functionAppHostname": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "The Function App default hostname the UI will query."
      }
    },
    "inputContainer": {
      "type": "string",
      "defaultValue": "input",
      "metadata": {
        "description": "Input blob container name."
      }
    },
    "outputContainer": {
      "type": "string",
      "defaultValue": "output",
      "metadata": {
        "description": "Output blob container name."
      }
    },
    "additionalEnvVars": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Additional environment variables (key/value object) merged into the container."
      }
    },
    "cpu": {
      "type": "string",
      "defaultValue": "0.5",
      "metadata": {
        "description": "CPU cores for the Streamlit container."
      }
    },
    "memory": {
      "type": "string",
      "defaultValue": "1Gi",
      "metadata": {
        "description": "Memory allocation for the Streamlit container."
      }
    },
    "minReplicas": {
      "type": "int",
      "defaultValue": 0,
      "metadata": {
        "description": "Minimum number of replicas."
      }
    },
    "maxReplicas": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Maximum number of replicas."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags applied to the Container App resources."
      }
    }
  },
  "variables": {
    "copy": [
      {
        "name": "customEnvVars",
        "count": "[length(items(parameters('additionalEnvVars')))]",
        "input": {
          "name": "[items(parameters('additionalEnvVars'))[copyIndex('customEnvVars')].key]",
          "value": "[string(items(parameters('additionalEnvVars'))[copyIndex('customEnvVars')].value)]"
        }
      }
    ],
    "managedEnvironmentName": "[toLower(take(format('{0}-env', parameters('namePrefix')), 60))]",
    "containerAppName": "[toLower(take(format('{0}-app', parameters('namePrefix')), 63))]",
    "baseEnvVars": [
      {
        "name": "STORAGE_ACCOUNT_NAME",
        "value": "[parameters('storageAccountName')]"
      },
      {
        "name": "FOUNDRY_PROJECT_ENDPOINT",
        "value": "[parameters('foundryProjectEndpoint')]"
      },
      {
        "name": "FUNCTION_APP_HOSTNAME",
        "value": "[parameters('functionAppHostname')]"
      },
      {
        "name": "INPUT_CONTAINER",
        "value": "[parameters('inputContainer')]"
      },
      {
        "name": "OUTPUT_CONTAINER",
        "value": "[parameters('outputContainer')]"
      }
    ],
    "allEnvVars": "[concat(variables('baseEnvVars'), variables('customEnvVars'))]"
  },
  "resources": [
    {
      "condition": "[parameters('enabled')]",
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('managedEnvironmentName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {}
    },
    {
      "condition": "[parameters('enabled')]",
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerAppName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('managedEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "http",
            "allowInsecure": true
          },
          "secrets": [
            {
              "name": "acr-password",
              "value": "[parameters('acrPassword')]"
            }
          ],
          "registries": [
            {
              "server": "[parameters('acrLoginServer')]",
              "username": "[parameters('acrUsername')]",
              "passwordSecretRef": "acr-password"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "streamlit",
              "image": "[format('{0}/{1}', parameters('acrLoginServer'), parameters('containerImage'))]",
              "resources": {
                "cpu": "[json(parameters('cpu'))]",
                "memory": "[parameters('memory')]"
              },
              "env": "[variables('allEnvVars')]"
            }
          ],
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": "[parameters('maxReplicas')]",
            "rules": [
              {
                "name": "http-rule",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('managedEnvironmentName'))]"
      ]
    }
  ],
  "outputs": {
    "streamlitEnabled": {
      "type": "bool",
      "value": "[parameters('enabled')]"
    },
    "streamlitAppName": {
      "type": "string",
      "value": "[coalesce(if(parameters('enabled'), variables('containerAppName'), null()), '')]"
    },
    "streamlitFqdn": {
      "type": "string",
      "value": "[coalesce(tryGet(tryGet(tryGet(tryGet(if(parameters('enabled'), reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'full'), null()), 'properties'), 'configuration'), 'ingress'), 'fqdn'), '')]"
    },
    "streamlitPrincipalId": {
      "type": "string",
      "value": "[coalesce(tryGet(tryGet(if(parameters('enabled'), reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01', 'full'), null()), 'identity'), 'principalId'), '')]"
    },
    "managedEnvironmentId": {
      "type": "string",
      "value": "[coalesce(if(parameters('enabled'), resourceId('Microsoft.App/managedEnvironments', variables('managedEnvironmentName')), null()), '')]"
    }
  }
}